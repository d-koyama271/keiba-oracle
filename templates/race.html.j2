<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ race.race_name }} | keiba-oracle</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f4f1ea;
      --panel: #fffdf8;
      --ink: #1f2520;
      --line: #d5ccbe;
      --accent: #32594d;
      --muted: #6f766c;
    }
    body {
      margin: 0;
      font-family: "Yu Gothic", "Hiragino Sans", sans-serif;
      background: linear-gradient(180deg, #f8f5ef 0%, #efe6d8 100%);
      color: var(--ink);
    }
    main {
      max-width: 1080px;
      margin: 0 auto;
      padding: 32px 20px 60px;
    }
    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 20px;
      margin-bottom: 18px;
      box-shadow: 0 10px 30px rgba(50, 89, 77, 0.06);
    }
    h1, h2 { margin-top: 0; }
    .meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
      font-size: 14px;
    }
    .status {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      background: #dde9e4;
      color: var(--accent);
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 12px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    th, td {
      text-align: left;
      padding: 10px 8px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }
    th {
      color: var(--muted);
      font-weight: 700;
    }
    .small {
      color: var(--muted);
      font-size: 13px;
    }
    a { color: var(--accent); }
    ul {
      margin: 0;
      padding-left: 18px;
    }
    .simulator-form {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      align-items: end;
      margin: 18px 0;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #f8f4ec;
    }
    .simulator-field {
      display: grid;
      gap: 6px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }
    .simulator-field input {
      width: 100%;
      box-sizing: border-box;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 10px;
      background: #fff;
      color: var(--ink);
      font: inherit;
    }
    .simulator-form button {
      border: 0;
      border-radius: 8px;
      padding: 11px 18px;
      background: var(--accent);
      color: #fff;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
    }
    .simulator-summary {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 18px;
      margin: 12px 0;
    }
    .simulator-error {
      color: #9b352b;
      font-weight: 700;
    }
    .table-scroll { overflow-x: auto; }
    [hidden] { display: none !important; }
  </style>
</head>
<body>
  <main>
    <div class="panel">
      <div class="status">{{ status }}</div>
      <h1>{{ race.track }} {{ race.race_number }}R {{ race.race_name }}</h1>
      <h2>レース基本情報</h2>
      <div class="meta">
        <div><strong>日付</strong><br>{{ race.date }}</div>
        <div><strong>発走</strong><br>{{ race.start_time or "-" }}</div>
        <div><strong>距離</strong><br>{{ race.surface or "-" }} {{ race.distance or "-" }}m</div>
        <div><strong>馬場</strong><br>{{ race.going or "-" }}</div>
        <div><strong>オッズ記録時刻</strong><br>{{ race.odds_captured_at or "-" }}</div>
        <div><strong>発走時点との差</strong><br>{{ odds_timing_label }}</div>
      </div>
      {% if odds_recorded_after_start %}<p class="small">※ 発走後に記録されたオッズスナップショットです。厳密な発走前オッズではありません。</p>{% endif %}
      <p class="small"><a href="../../index.html">一覧へ戻る</a> / <a href="{{ race.source_url }}">netkeiba</a></p>
    </div>

    <div class="panel">
      <h2>予想</h2>
      {% if prediction %}
      <table>
        <thead>
          <tr>
            <th>馬番</th>
            <th>馬名</th>
            <th>騎手</th>
            <th>単勝オッズ</th>
            <th>人気</th>
            <th>1着確率</th>
            <th>理由</th>
          </tr>
        </thead>
        <tbody>
          {% for horse in horse_rows %}
          <tr>
            <td>{{ horse.horse_number }}</td>
            <td>{{ horse.horse_name }}</td>
            <td>{{ horse.jockey or "-" }}</td>
            <td>{{ horse.win_odds if horse.win_odds is not none else "-" }}</td>
            <td>{{ horse.popularity if horse.popularity is not none else "-" }}</td>
            <td>
              {% if horse.prediction %}
                {{ "%.1f"|format(horse.prediction.win_probability * 100) }}%
              {% else %}
                -
              {% endif %}
            </td>
            <td>{{ horse.prediction.reason if horse.prediction else "-" }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% if prediction.optional_summary %}
      <p><strong>総括:</strong> {{ prediction.optional_summary }}</p>
      {% endif %}
      {% else %}
      <p>prediction はまだ生成されていません。</p>
      {% endif %}
    </div>

    <div class="panel">
      <h2>基準設定による購入想定</h2>
      {% if simulation_pre %}
      <p class="small">
        予算上限 {{ simulation_pre.budget }}円 /
        最低EV {{ simulation_pre.ev_threshold }} /
        Kelly係数 {{ simulation_pre.kelly_fraction }} /
        購入単位 {{ custom_simulation_data.stake_unit }}円
      </p>
      {% endif %}
      {% if simulation_pre and simulation_pre.selections %}
      <table>
        <thead>
          <tr>
            <th>馬番</th>
            <th>暗黙確率</th>
            <th>予想確率</th>
            <th>EV</th>
            <th>Kelly</th>
            <th>配分</th>
            <th>購入額</th>
          </tr>
        </thead>
        <tbody>
          {% for item in simulation_pre.selections %}
          <tr>
            <td>{{ item.horse_number }}</td>
            <td>{{ "%.3f"|format(item.implied_probability) }}</td>
            <td>{{ "%.3f"|format(item.predicted_probability) }}</td>
            <td>{{ "%.3f"|format(item.expected_value) }}</td>
            <td>{{ "%.4f"|format(item.kelly_weight_raw) }}</td>
            <td>{{ "%.2f"|format(item.allocation_ratio * 100) }}%</td>
            <td>{{ item.stake }}円</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p>購入条件を満たすシミュレーション候補はありません。</p>
      {% endif %}
    </div>

    {% if simulation_pre and custom_simulation_data.horses %}
    <div class="panel" id="custom-simulator">
      <h2>購入シミュレーション</h2>
      <p class="small">入力内容と計算結果はこの画面内だけで使用し、正式な購入想定・収支・feedbackには反映しません。</p>
      <form class="simulator-form" id="custom-simulator-form">
        <label class="simulator-field">
          予算（円）
          <input name="budget" type="number" min="{{ custom_simulation_data.stake_unit }}" step="1" value="{{ simulation_pre.budget }}" required>
        </label>
        <label class="simulator-field">
          最低EV
          <input name="ev_threshold" type="number" min="1" step="0.01" value="{{ simulation_pre.ev_threshold }}" required>
        </label>
        <label class="simulator-field">
          Kelly係数
          <input name="kelly_fraction" type="number" min="0" max="1" step="0.05" value="{{ simulation_pre.kelly_fraction }}" required>
        </label>
        <button type="submit">再計算</button>
      </form>
      <p class="small">最低EV 1.05は、期待払戻が投資額の1.05倍以上であることを示します。購入単位は{{ custom_simulation_data.stake_unit }}円です。</p>
      <p class="simulator-error" id="custom-simulator-error" role="alert" hidden></p>
      <div id="custom-simulator-result" aria-live="polite">
        <p id="custom-simulator-empty" hidden><strong>購入なし</strong></p>
        <div class="simulator-summary" id="custom-simulator-summary" hidden>
          <span>計算予算: <strong id="custom-simulator-budget">0円</strong></span>
          <span>合計購入額: <strong id="custom-simulator-total">0円</strong></span>
          <span>未使用予算: <strong id="custom-simulator-unused">0円</strong></span>
        </div>
        <div class="table-scroll" id="custom-simulator-table" hidden>
          <table>
            <thead>
              <tr>
                <th>馬番</th>
                <th>予測勝率</th>
                <th>単勝オッズ</th>
                <th>EV</th>
                <th>Kelly値</th>
                <th>購入金額</th>
              </tr>
            </thead>
            <tbody id="custom-simulator-rows"></tbody>
          </table>
        </div>
      </div>
    </div>
    <script type="application/json" id="custom-simulator-data">{{ custom_simulation_data | tojson }}</script>
    <script>
      function calculateCustomSimulation(horses, budget, evThreshold, kellyFraction, stakeUnit) {
        const candidates = [];
        for (const horse of horses) {
          const horseNumber = Number(horse.horse_number);
          const predictedProbability = Number(horse.win_probability);
          const odds = Number(horse.win_odds);
          if (!Number.isFinite(predictedProbability) || predictedProbability < 0 || !Number.isFinite(odds) || odds <= 1) {
            continue;
          }
          const impliedProbability = 1 / odds;
          const expectedValue = predictedProbability * odds;
          const b = odds - 1;
          const fullKelly = Math.max(0, ((b * predictedProbability) - (1 - predictedProbability)) / b);
          const fractionalKelly = fullKelly * kellyFraction;
          if (expectedValue + 1e-12 < evThreshold || fullKelly <= 0 || fractionalKelly <= 0) {
            continue;
          }
          candidates.push({
            horse_number: horseNumber,
            implied_probability: impliedProbability,
            predicted_probability: predictedProbability,
            expected_value: expectedValue,
            kelly_weight_raw: fractionalKelly,
            raw_stake: budget * fractionalKelly,
          });
        }

        candidates.sort((left, right) =>
          (right.expected_value - left.expected_value) || (left.horse_number - right.horse_number)
        );
        const totalRawStake = candidates.reduce((total, item) => total + item.raw_stake, 0);
        const scale = totalRawStake > budget ? budget / totalRawStake : 1;
        const selections = [];
        for (const candidate of candidates) {
          const stake = Math.floor(((candidate.raw_stake * scale) / stakeUnit) + 1e-12) * stakeUnit;
          if (stake < stakeUnit) {
            continue;
          }
          selections.push({
            horse_number: candidate.horse_number,
            implied_probability: candidate.implied_probability,
            predicted_probability: candidate.predicted_probability,
            expected_value: candidate.expected_value,
            kelly_weight_raw: candidate.kelly_weight_raw,
            allocation_ratio: stake / budget,
            stake,
          });
        }
        const totalStake = selections.reduce((total, item) => total + item.stake, 0);
        return {
          budget,
          selections,
          total_stake: totalStake,
          unused_budget: budget - totalStake,
        };
      }

      (() => {
        const root = document.getElementById("custom-simulator");
        if (!root) {
          return;
        }
        const data = JSON.parse(document.getElementById("custom-simulator-data").textContent);
        const form = document.getElementById("custom-simulator-form");
        const error = document.getElementById("custom-simulator-error");
        const empty = document.getElementById("custom-simulator-empty");
        const summary = document.getElementById("custom-simulator-summary");
        const table = document.getElementById("custom-simulator-table");
        const rows = document.getElementById("custom-simulator-rows");
        const budgetOutput = document.getElementById("custom-simulator-budget");
        const totalOutput = document.getElementById("custom-simulator-total");
        const unusedOutput = document.getElementById("custom-simulator-unused");
        const yen = new Intl.NumberFormat("ja-JP");

        const addCell = (row, value) => {
          const cell = document.createElement("td");
          cell.textContent = value;
          row.appendChild(cell);
        };

        const recalculate = () => {
          const enteredBudget = Number(form.elements.budget.value);
          const evThreshold = Number(form.elements.ev_threshold.value);
          const kellyFraction = Number(form.elements.kelly_fraction.value);
          const stakeUnit = Number(data.stake_unit);
          let message = "";
          if (!Number.isInteger(enteredBudget) || enteredBudget <= 0) {
            message = "予算は正の整数で入力してください。";
          } else if (!Number.isFinite(evThreshold) || evThreshold < 1) {
            message = "最低EVは1.0以上で入力してください。";
          } else if (!Number.isFinite(kellyFraction) || kellyFraction < 0 || kellyFraction > 1) {
            message = "Kelly係数は0以上1以下で入力してください。";
          }
          const budget = Math.floor(enteredBudget / stakeUnit) * stakeUnit;
          if (!message && budget < stakeUnit) {
            message = `予算は購入単位の${stakeUnit}円以上にしてください。`;
          }
          error.textContent = message;
          error.hidden = !message;
          if (message) {
            empty.hidden = true;
            summary.hidden = true;
            table.hidden = true;
            return;
          }

          const result = calculateCustomSimulation(data.horses, budget, evThreshold, kellyFraction, stakeUnit);
          budgetOutput.textContent = `${yen.format(result.budget)}円`;
          totalOutput.textContent = `${yen.format(result.total_stake)}円`;
          unusedOutput.textContent = `${yen.format(result.unused_budget)}円`;
          summary.hidden = false;
          empty.hidden = result.selections.length > 0;
          table.hidden = result.selections.length === 0;
          rows.replaceChildren();
          for (const item of result.selections) {
            const row = document.createElement("tr");
            addCell(row, String(item.horse_number));
            addCell(row, `${(item.predicted_probability * 100).toFixed(2)}%`);
            addCell(row, item.implied_probability ? (1 / item.implied_probability).toFixed(1) : "-");
            addCell(row, item.expected_value.toFixed(3));
            addCell(row, item.kelly_weight_raw.toFixed(4));
            addCell(row, `${yen.format(item.stake)}円`);
            rows.appendChild(row);
          }
        };

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          recalculate();
        });
        recalculate();
      })();
    </script>
    {% endif %}

    {% if result %}
    <div class="panel">
      <h2>実結果</h2>
      <p><strong>着順:</strong> {{ result.finish_order | join(" - ") }}</p>
      <table>
        <thead>
          <tr>
            <th>馬番</th>
            <th>着順</th>
            <th>単勝払戻</th>
          </tr>
        </thead>
        <tbody>
          {% for item in result_rows %}
          <tr>
            <td>{{ item.horse_number }}</td>
            <td>{{ item.finish_position }}</td>
            <td>{{ item.payout_per_100 if item.payout_per_100 is not none else "-" }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {% if simulation_post %}
    <div class="panel">
      <h2>購入結果</h2>
      {% if simulation_post.total_stake == 0 or (simulation_pre and not simulation_pre.selections) %}
      <p><strong>購入なし</strong></p>
      <p>
        <strong>投資:</strong> {{ simulation_post.total_stake }}円 /
        <strong>回収:</strong> {{ simulation_post.total_return }}円 /
        <strong>損益:</strong> {{ simulation_post.profit }}円
      </p>
      {% else %}
      <p>
        <strong>投資:</strong> {{ simulation_post.total_stake }}円 /
        <strong>回収:</strong> {{ simulation_post.total_return }}円 /
        <strong>損益:</strong> {{ simulation_post.profit }}円 /
        <strong>ROI:</strong> {{ "%.2f"|format(simulation_post.roi * 100) }}%
      </p>
      <table>
        <thead>
          <tr>
            <th>馬番</th>
            <th>購入額</th>
            <th>的中</th>
            <th>払戻</th>
            <th>回収額</th>
            <th>損益</th>
          </tr>
        </thead>
        <tbody>
          {% for item in simulation_post.selections %}
          <tr>
            <td>{{ item.horse_number }}</td>
            <td>{{ item.stake }}円</td>
            <td>{{ "yes" if item.hit else "no" }}</td>
            <td>{{ item.payout if item.payout else "-" }}</td>
            <td>{{ item.return_amount }}円</td>
            <td>{{ item.profit }}円</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}
    </div>
    {% endif %}

    {% if feedback %}
    <div class="panel">
      <h2>フィードバック要約</h2>
      <ul>
        <li><strong>確率誤差:</strong> {{ feedback.probability_error_summary }}</li>
        <li><strong>順位誤差:</strong> {{ feedback.ranking_error_summary }}</li>
        <li><strong>収支:</strong> {{ feedback.profit_summary }}</li>
        <li><strong>補正メモ:</strong> {{ feedback.calibration_notes }}</li>
        <li><strong>次回調整:</strong> {{ feedback.next_prediction_adjustment_summary }}</li>
      </ul>
    </div>
    {% endif %}
  </main>
</body>
</html>
